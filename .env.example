# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual secrets.

POSTGRES_USER=movieuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=moviedb

# Used to sign JWT tokens. Generate a real one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme

JWT_EXPIRE_MINUTES=60

# Get a free key at https://www.themoviedb.org/settings/api (Developer tier).
# Leave blank to run without posters — everything else still works.
TMDB_API_KEY=changeme
